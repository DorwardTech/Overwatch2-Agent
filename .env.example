# --- Required ---------------------------------------------------------------
# Full central ingest endpoint.
CENTRAL_API_URL=https://ow2.lasertag.net.au/api/agent/ingest
# This venue's agent token (Overwatch → Sites → edit the site → Generate token).
AGENT_TOKEN=OW2_replace_me

# --- O-Zone connection ------------------------------------------------------
# The local O-Zone server. Use its LAN IP, or host.docker.internal if O-Zone
# runs on the same machine as Docker.
OZONE_WS_HOST=host.docker.internal
OZONE_WS_PORT=12113

# --- Post-game results (optional) -------------------------------------------
# Requires the O-Zone scoresheet-printing licence (binary results API on :12123).
# When on, the agent fetches each finished game's hit-zone + fitness data and
# posts it to central's /api/agent/game-results.
ENABLE_GAME_RESULTS=true
OZONE_RESULTS_PORT=12123
# On connect, O-Zone pushes a fixed handshake (texts + event_types) the agent
# must drain before requesting a game. Default 2; only change if your O-Zone
# firmware sends a different number of initial messages.
# OZONE_RESULTS_HANDSHAKE=2

# --- Command queue (optional) -----------------------------------------------
# The agent polls central for queued commands (e.g. re-fetch a game's results)
# and acknowledges the outcome. On by default; set false to disable two-way
# control. Re-fetch commands use the results API, so the scoresheet licence
# above is required for them to succeed.
ENABLE_COMMANDS=true

# --- Optional tuning (defaults shown) ---------------------------------------
POLL_INTERVAL=2            # pack poll rate (s) while a GAME IS ACTIVE
SLOW_POLL_INTERVAL=60      # pack poll rate (s) when idle; also the cadence for
#                            #   teams/games/licences metadata + command checks
# BUFFER_MAX=2000            # max pushes buffered if central is unreachable
# HEALTH_ADDR=:8088          # agent health endpoint bind address

# --- Print-server cache + transparent proxy (optional, opt-in) --------------
# When enabled, the agent pulls finished games from O-Zone's print server ONLY
# while idle, caches them byte-for-byte, and serves them to TORN/printers via a
# proxy on :12123 — so the real print server is never hit during a live game.
# Reconfigure TORN to point at this agent's LAN IP:12123 instead of O-Zone.
#
# ENABLE_CACHE=true          # maintain the local verbatim game cache
# ENABLE_PROXY=true          # serve cached games over the O-Zone TCP protocol
# PROXY_LISTEN_ADDR=0.0.0.0:12123   # LAN-bound; NEVER port-forward to the internet
# CACHE_DIR=/data/cache      # on-disk cache (mount a writable volume)
# CACHE_RETENTION_HOURS=24   # prune cached games older than this
#
# Game-state detection for idle-gating. The External Message Bus (:12111) gives
# precise, event-driven start/finish; WS SERVERMODE is the backstop.
# ENABLE_MSG_BUS=true        # consume O-Zone's External Message Bus
# OZONE_MSG_BUS_PORT=12111
# GAME_FINISH_DELAY=15       # seconds to wait after game-finish before fetching
#
# Failover: back each cached game up to central, and restore on cold start.
# ENABLE_CENTRAL_FAILOVER=true   # (default true when the cache is on)
#
# Token-protected admin/control API (overview/games/resync/purge). Both required.
# ADMIN_API_ADDR=:8090
# ADMIN_API_TOKEN=change_me
